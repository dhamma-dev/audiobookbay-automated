# Copy to .env and fill in what you use. Every setting is optional unless the
# feature it enables is one you want; unset keys simply hide their feature.
# The README explains each section in detail.

# --- Download client (required) ------------------------------------------------
# One of: qbittorrent | transmission | delugeweb | putio
DOWNLOAD_CLIENT=qbittorrent
DL_HOST=192.168.1.10
DL_PORT=8080
DL_USERNAME=admin
DL_PASSWORD=change-me
# DL_URL=http://192.168.1.10:8112        # Deluge prefers a full URL
# DL_CATEGORY=Audiobookbay-Audiobooks
# SAVE_PATH_BASE=/audiobooks             # per-book subfolders are created here

# --- put.io (only when DOWNLOAD_CLIENT=putio) -----------------------------------
# PUTIO_CLIENT_ID=
# PUTIO_CLIENT_SECRET=
# PUTIO_ACCESS_TOKEN=
# PUTIO_SAVE_PARENT_ID=

# --- AudiobookBay + Tor ----------------------------------------------------------
# ABB_HOSTNAME=audiobookbay.lu
# USE_TOR=true                 # default route for new visitors (each browser can toggle)
# TOR_AUTOSTART=true
# REQUEST_TIMEOUT=45           # seconds per ABB fetch; 0/off = unbounded

# NOTE: the feature keys below (Gemini / Audiobookshelf / Hardcover) can also
# be set on the in-app Settings page — most recently set wins.

# --- Smart sort (optional, Gemini) -------------------------------------------------
# GEMINI_API_KEY=
# RANK_MODEL=gemini-3.5-flash
# SMART_PREFETCH_DEFAULT=off
# PREFERRED_LANGUAGE=English

# --- Audiobookshelf "in your library" matching (optional) ---------------------------
# ABS_URL=https://audiobooks.example.com
# ABS_TOKEN=
# ABS_LIBRARY_ID=
# ABS_LOW_KBPS=63              # Upgrade Radar: flag owned copies at/below this

# --- Download log (on by default at /data/downloads.db) ------------------------------
# LOG_DB_PATH=/data/downloads.db
# LOG_ADMIN_USERS=alice,bob    # who may see everyone's entries on /log

# --- Hardcover wanted list (optional) --------------------------------------------------
# HARDCOVER_API_KEY=
# WANTED_AUTO_DOWNLOAD=false   # strict auto-send: STRONG match AND M4B only
# WANTED_LLM=true              # one small Gemini verdict per found book (needs GEMINI_API_KEY)
# WANTED_ROUTE=default         # background search route: default | tor | direct

# --- Server (v2) -------------------------------------------------------------------------
# FLASK_SECRET_KEY=            # else generated once and persisted under /data
# LOG_LEVEL=INFO
# COOKIE_SECURE=false          # set true when serving over HTTPS
# COVER_PROXY=false            # stream result covers through the Tor/Direct route
